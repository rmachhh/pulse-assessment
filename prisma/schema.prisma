// Pulse — coordination store only. Nothing here is durable user data:
// rows are deleted on leave, on staleness, or after a signal is delivered.
// Chat text and video are NOT modeled — they ride WebRTC peer-to-peer and
// never reach the server.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Presence {
  id         String   @id // public session uuid shown to other peers
  secretHash String // hash of private per-session ownership secret
  lat        Float // ALREADY privacy-offset coords (raw is never stored)
  lng        Float
  busy       Boolean  @default(false) // true while in an active connection
  lastSeen   DateTime

  @@index([lastSeen])
}

model Signal {
  // Mailbox for connection requests + WebRTC signaling only.
  id        String   @id @default(uuid())
  toId      String // recipient session id
  fromId    String // sender session id
  type      String // request | accept | decline | offer | answer | ice | end
  payload   String? // JSON string (SDP / ICE candidate)
  createdAt DateTime @default(now())

  @@index([toId])
}

model Connection {
  // Transient pairing state for one request/active chat. Deleted when declined,
  // ended, or when either side leaves/stales out.
  id          String   @id @default(uuid())
  requesterId String
  targetId    String
  status      String // pending | accepted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([requesterId])
  @@index([targetId])
  @@index([status])
}

model RateLimit {
  // Fixed-window counters for lightweight API abuse protection.
  key       String   @id
  count     Int
  expiresAt DateTime
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}
